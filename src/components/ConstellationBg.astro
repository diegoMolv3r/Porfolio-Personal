<!-- Constellation Background — Animated SVG network of nodes and connections -->
<div class="constellation-container" aria-hidden="true">
  <svg
    class="constellation-svg"
    viewBox="0 0 1440 900"
    preserveAspectRatio="xMidYMid slice"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <radialGradient id="node-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="var(--accent-cyan)" stop-opacity="0.8" />
        <stop offset="100%" stop-color="var(--accent-cyan)" stop-opacity="0" />
      </radialGradient>
      <radialGradient id="node-glow-indigo" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="var(--accent-indigo)" stop-opacity="0.6" />
        <stop offset="100%" stop-color="var(--accent-indigo)" stop-opacity="0" />
      </radialGradient>
    </defs>

    <!-- Connection lines -->
    <g class="connections" stroke="var(--accent-cyan)" stroke-width="0.5" opacity="0.15">
      <line x1="120" y1="80"  x2="300" y2="200" class="line-anim" style="--delay:0s" />
      <line x1="300" y1="200" x2="520" y2="150" class="line-anim" style="--delay:0.3s" />
      <line x1="520" y1="150" x2="700" y2="320" class="line-anim" style="--delay:0.6s" />
      <line x1="700" y1="320" x2="950" y2="250" class="line-anim" style="--delay:0.9s" />
      <line x1="950" y1="250" x2="1150" y2="400" class="line-anim" style="--delay:1.2s" />
      <line x1="1150" y1="400" x2="1350" y2="300" class="line-anim" style="--delay:1.5s" />
      <line x1="200" y1="500" x2="400" y2="420" class="line-anim" style="--delay:0.5s" />
      <line x1="400" y1="420" x2="600" y2="550" class="line-anim" style="--delay:0.8s" />
      <line x1="600" y1="550" x2="850" y2="480" class="line-anim" style="--delay:1.1s" />
      <line x1="850" y1="480" x2="1050" y2="600" class="line-anim" style="--delay:1.4s" />
      <line x1="1050" y1="600" x2="1300" y2="520" class="line-anim" style="--delay:1.7s" />
      <line x1="300" y1="200" x2="400" y2="420" class="line-anim" style="--delay:1.0s" />
      <line x1="520" y1="150" x2="600" y2="550" class="line-anim" style="--delay:1.3s" />
      <line x1="700" y1="320" x2="850" y2="480" class="line-anim" style="--delay:1.6s" />
      <line x1="950" y1="250" x2="1050" y2="600" class="line-anim" style="--delay:1.9s" />
      <line x1="80"  y1="700" x2="300" y2="650" class="line-anim" style="--delay:0.7s" />
      <line x1="300" y1="650" x2="600" y2="750" class="line-anim" style="--delay:1.0s" />
      <line x1="600" y1="750" x2="900" y2="700" class="line-anim" style="--delay:1.3s" />
      <line x1="900" y1="700" x2="1200" y2="800" class="line-anim" style="--delay:1.6s" />
      <line x1="600" y1="550" x2="600" y2="750" class="line-anim" style="--delay:1.8s" />
    </g>

    <!-- Primary nodes (Cyan) -->
    <g class="nodes-cyan">
      <circle cx="120" cy="80"  r="2.5" class="node-cyan" style="--delay:0.1s" />
      <circle cx="300" cy="200" r="3"   class="node-cyan" style="--delay:0.3s" />
      <circle cx="520" cy="150" r="2"   class="node-cyan" style="--delay:0.5s" />
      <circle cx="700" cy="320" r="3.5" class="node-cyan" style="--delay:0.7s" />
      <circle cx="950" cy="250" r="2"   class="node-cyan" style="--delay:0.9s" />
      <circle cx="1150" cy="400" r="3"  class="node-cyan" style="--delay:1.1s" />
      <circle cx="1350" cy="300" r="2.5" class="node-cyan" style="--delay:1.3s" />
    </g>

    <!-- Secondary nodes (Cyan lower row) -->
    <g class="nodes-cyan-2">
      <circle cx="200" cy="500" r="2"   class="node-cyan" style="--delay:0.2s" />
      <circle cx="400" cy="420" r="2.5" class="node-cyan" style="--delay:0.6s" />
      <circle cx="600" cy="550" r="3"   class="node-cyan" style="--delay:0.8s" />
      <circle cx="850" cy="480" r="2"   class="node-cyan" style="--delay:1.0s" />
      <circle cx="1050" cy="600" r="2.5" class="node-cyan" style="--delay:1.2s" />
      <circle cx="1300" cy="520" r="2"   class="node-cyan" style="--delay:1.5s" />
    </g>

    <!-- Third row nodes -->
    <g class="nodes-cyan-3">
      <circle cx="80"  cy="700" r="2"   class="node-cyan" style="--delay:0.4s" />
      <circle cx="300" cy="650" r="2.5" class="node-cyan" style="--delay:0.7s" />
      <circle cx="600" cy="750" r="3"   class="node-cyan" style="--delay:1.0s" />
      <circle cx="900" cy="700" r="2"   class="node-cyan" style="--delay:1.2s" />
      <circle cx="1200" cy="800" r="2.5" class="node-cyan" style="--delay:1.5s" />
    </g>

    <!-- Indigo accent nodes (fewer, larger glow) -->
    <g class="nodes-indigo">
      <circle cx="700" cy="320" r="8" fill="url(#node-glow-indigo)" class="node-indigo-glow" style="--delay:0.5s" />
      <circle cx="300" cy="200" r="6" fill="url(#node-glow)" class="node-indigo-glow" style="--delay:1.0s" />
      <circle cx="1050" cy="600" r="7" fill="url(#node-glow-indigo)" class="node-indigo-glow" style="--delay:1.5s" />
      <circle cx="600" cy="750" r="6" fill="url(#node-glow)" class="node-indigo-glow" style="--delay:2.0s" />
    </g>
  </svg>

  <!-- Ambient glow orbs -->
  <div class="glow-orb orb-1"></div>
  <div class="glow-orb orb-2"></div>
  <div class="glow-orb orb-3"></div>
</div>

<style>
  .constellation-container {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .constellation-svg {
    width: 100%;
    height: 100%;
    opacity: 0.6;
  }

  /* Node animations */
  .node-cyan {
    fill: var(--accent-cyan);
    opacity: 0;
    animation: node-appear 1s ease-out forwards, node-pulse-anim 4s ease-in-out infinite;
    animation-delay: var(--delay), calc(var(--delay) + 1s);
  }

  @keyframes node-appear {
    0%   { opacity: 0; r: 0; }
    100% { opacity: 0.7; }
  }

  @keyframes node-pulse-anim {
    0%, 100% { opacity: 0.4; }
    50%      { opacity: 0.9; }
  }

  /* Line draw animation */
  .line-anim {
    stroke-dasharray: 500;
    stroke-dashoffset: 500;
    animation: draw-line-anim 2s ease-out forwards;
    animation-delay: var(--delay);
  }

  @keyframes draw-line-anim {
    0%   { stroke-dashoffset: 500; }
    100% { stroke-dashoffset: 0; }
  }

  /* Indigo glow nodes float */
  .node-indigo-glow {
    opacity: 0;
    animation: glow-node-appear 1.5s ease-out forwards, float-organic 8s ease-in-out infinite;
    animation-delay: var(--delay), calc(var(--delay) + 1.5s);
  }

  @keyframes glow-node-appear {
    0%   { opacity: 0; }
    100% { opacity: 0.5; }
  }

  /* Ambient glow orbs */
  .glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.08;
  }

  .orb-1 {
    width: 600px;
    height: 600px;
    background: var(--accent-cyan);
    top: -200px;
    right: -200px;
    animation: float-slow 10s ease-in-out infinite;
  }

  .orb-2 {
    width: 500px;
    height: 500px;
    background: var(--accent-indigo);
    bottom: -150px;
    left: -150px;
    animation: float-slow 12s ease-in-out infinite reverse;
  }

  .orb-3 {
    width: 400px;
    height: 400px;
    background: var(--accent-cyan);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: float-organic 15s ease-in-out infinite;
    opacity: 0.04;
  }
</style>
