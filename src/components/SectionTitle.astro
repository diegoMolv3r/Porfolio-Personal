---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="section-title-wrapper scroll-hidden">
  <div class="flex items-center justify-center gap-4 mb-2">
    <span class="title-line left"></span>
    <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-center gradient-text tracking-tight">
      {title}
    </h2>
    <span class="title-line right"></span>
  </div>
  {subtitle && (
    <p class="text-center text-[var(--text-secondary)] text-base md:text-lg max-w-2xl mx-auto mt-3">
      {subtitle}
    </p>
  )}
</div>

<style>
  .section-title-wrapper {
    margin-bottom: 4.5rem;
  }

  .title-line {
    display: block;
    height: 1px;
    width: 3rem;
    background: linear-gradient(90deg, transparent, var(--accent-cyan), transparent);
    opacity: 0.6;
  }

  @media (min-width: 768px) {
    .title-line {
      width: 5rem;
    }
  }
</style>
