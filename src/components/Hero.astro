---
import GlowButton from "./GlowButton.astro";
---

<section
  id="home-section"
  class="min-h-screen flex items-center justify-center pt-20 pb-28 px-4 relative overflow-hidden"
>
  <div class="max-w-7xl mx-auto w-full flex flex-col md:flex-row items-center justify-between gap-10 md:gap-16">
    <!-- Text content -->
    <div class="flex-1 flex flex-col items-center md:items-start text-center md:text-left space-y-5 z-10">
      <!-- Tag -->
      <div class="animate-reveal-up" style="animation-delay: 0.1s;">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[var(--border-glow)] bg-[var(--accent-cyan)]/5 text-[var(--accent-cyan)] text-xs font-mono tracking-wider">
          <span class="w-2 h-2 rounded-full bg-[var(--accent-cyan)] animate-glow-pulse"></span>
          OPEN TO WORK
        </span>
      </div>

      <!-- Hero title -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight leading-tight animate-reveal-up" style="animation-delay: 0.3s;">
        Diego Luciano
        <br />
        <span class="gradient-text-glow">Molver</span>
      </h1>

      <!-- Subtitle -->
      <h2 class="text-xl sm:text-2xl md:text-3xl font-semibold text-[var(--accent-cyan)] animate-reveal-up" style="animation-delay: 0.5s;">
        Desarrollador Web Full Stack
      </h2>

      <!-- Description -->
      <p class="text-base md:text-lg text-[var(--text-secondary)] max-w-lg leading-relaxed animate-reveal-up" style="animation-delay: 0.7s;">
        Estudiante universitario en constante aprendizaje, interesado en la
        <span class="text-[var(--accent-cyan)] font-medium">Ciberseguridad</span> y las buenas prácticas de programación.
      </p>

      <!-- Social links -->
      <div class="flex items-center gap-5 mt-2 animate-reveal-up" style="animation-delay: 0.9s;">
        <a
          href="https://www.linkedin.com/in/diego-molver-72b3a727b/"
          target="_blank"
          rel="noopener noreferrer"
          class="social-icon"
          aria-label="LinkedIn"
        >
          <i class="bi bi-linkedin text-xl md:text-2xl"></i>
        </a>
        <a
          href="https://github.com/diegoMolv3r"
          target="_blank"
          rel="noopener noreferrer"
          class="social-icon"
          aria-label="GitHub"
        >
          <i class="bi bi-github text-xl md:text-2xl"></i>
        </a>
        <a
          href="mailto:molverdiego@gmail.com"
          target="_blank"
          rel="noopener noreferrer"
          class="social-icon"
          aria-label="Email"
        >
          <i class="bi bi-envelope text-xl md:text-2xl"></i>
        </a>
      </div>

      <!-- CTA buttons -->
      <div class="flex flex-wrap gap-3 mt-3 animate-reveal-up" style="animation-delay: 1.1s;">
        <GlowButton
          href="/assets/Molver Diego Cv.pdf"
          text="Descargar CV"
          icon="bi bi-download"
          target="_blank"
          variant="primary"
        />
        <GlowButton
          href="#projects-section"
          text="Ver Proyectos"
          icon="bi bi-arrow-down"
          variant="outline"
        />
      </div>
    </div>

    <!-- Video / Avatar -->
    <div class="relative animate-reveal-scale flex-shrink-0" style="animation-delay: 0.6s;">
      <!-- Glow ring -->
      <div class="absolute inset-0 rounded-full bg-gradient-to-br from-[var(--accent-cyan)] to-[var(--accent-indigo)] opacity-20 blur-xl scale-110 animate-glow-pulse"></div>

      <video
        src="/assets/video/AnimadoEscribiendo.mp4"
        class="relative z-10 h-52 w-52 md:h-72 md:w-72 lg:h-80 lg:w-80 object-cover rounded-full border-2 border-[var(--accent-cyan)]/40 shadow-2xl"
        autoplay
        loop
        muted
        playsinline
      ></video>

      <!-- Floating decorative elements -->
      <div class="absolute -top-4 -right-4 w-8 h-8 rounded-lg bg-[var(--accent-cyan)]/20 border border-[var(--accent-cyan)]/30 animate-float-organic" style="animation-delay: 0.5s;"></div>
      <div class="absolute -bottom-3 -left-3 w-6 h-6 rounded-full bg-[var(--accent-indigo)]/20 border border-[var(--accent-indigo)]/30 animate-float-organic" style="animation-delay: 1.5s;"></div>
      <div class="absolute top-1/2 -right-8 w-4 h-4 rounded-full bg-[var(--accent-cyan)]/30 animate-float-slow" style="animation-delay: 2s;"></div>
    </div>
  </div>

  <!-- Bottom gradient fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[var(--bg-deepest)] to-transparent pointer-events-none"></div>
</section>

<style>
  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.75rem;
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    background: var(--bg-card);
  }

  .social-icon:hover {
    color: var(--accent-cyan);
    border-color: var(--accent-cyan);
    box-shadow: var(--glow-cyan);
    transform: translateY(-3px) scale(1.05);
    background: rgba(56, 189, 248, 0.08);
  }
</style>
