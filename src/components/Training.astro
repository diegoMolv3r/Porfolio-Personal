---
import SectionTitle from "./SectionTitle.astro";

const TRAINING = [
  {
    titulo: "Tec. Universitaria en Desarrollo Web",
    institucion: "Universidad Nacional de La Matanza",
    periodo: "Abril 2024 - Actualidad (17/20 materias)",
    destacado: true,
  },
  {
    titulo: "Iniciación al Desarrollo con IA",
    institucion: "Big School",
    periodo: "Marzo 2026",
    destacado: false,
  },
  {
    titulo: "Introducción a la Ciberseguridad",
    institucion: "Fundación YPF",
    periodo: "Diciembre 2025",
    destacado: false,
  },
  {
    titulo: "Professional Front-End Developer",
    institucion: "Universidad Tecnológica Nacional",
    periodo: "Marzo 2023 - Diciembre 2023",
    destacado: false,
  },
  {
    titulo: "Desarrollo Web con Bootstrap 5",
    institucion: "Universidad Tecnológica Nacional",
    periodo: "Diciembre 2023",
    destacado: false,
  },
  {
    titulo: "HTML5, CSS3 y JS ES6+",
    institucion: "Universidad Tecnológica Nacional",
    periodo: "Septiembre 2023 - Noviembre 2023",
    destacado: false,
  },
  {
    titulo: "Desarrollo Web con JavaScript",
    institucion: "Universidad Tecnológica Nacional",
    periodo: "Julio 2023 - Septiembre 2023",
    destacado: false,
  },
  {
    titulo: "Desarrollo Web con HTML5 y CSS3",
    institucion: "Universidad Tecnológica Nacional",
    periodo: "Marzo 2023 - Mayo 2023",
    destacado: false,
  },
];
---

<section
  id="educacion-section"
  class="py-28 md:py-36 max-w-7xl mx-auto w-full px-4 relative"
>
  <SectionTitle title="FORMACIÓN ACADÉMICA" subtitle="Mi recorrido educativo y certificaciones" />

  <div
    class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 scroll-hidden"
  >
    {
      TRAINING.map((train, index) => (
        <article
          class:list={[
            "training-card glass p-6 md:p-7 flex flex-col",
            train.destacado && "border-[var(--accent-cyan)]/25 bg-gradient-to-br from-[var(--accent-cyan)]/5 to-transparent"
          ]}
          data-stagger
          style={`transition-delay: ${index * 0.08}s`}
        >
          {/* Accent top bar */}
          <div class:list={[
            "h-[2px] w-full -mt-6 md:-mt-7 mb-5 rounded-full",
            train.destacado
              ? "bg-gradient-to-r from-[var(--accent-cyan)] to-[var(--accent-indigo)]"
              : "bg-gradient-to-r from-[var(--accent-cyan)]/30 to-transparent"
          ]} />

          <div class="flex items-start gap-3 mb-4">
            <div class:list={[
              "w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0",
              train.destacado
                ? "bg-[var(--accent-cyan)]/20 border border-[var(--accent-cyan)]/30"
                : "bg-[var(--bg-card)] border border-[var(--border-subtle)]"
            ]}>
              <i class:list={[
                "bi bi-mortarboard text-lg",
                train.destacado ? "text-[var(--accent-cyan)]" : "text-[var(--text-muted)]"
              ]} />
            </div>
            <h3 class="text-base font-semibold text-[var(--text-primary)] leading-tight">
              {train.titulo}
            </h3>
          </div>

          <div class="space-y-2 mt-auto">
            <div class="flex items-center gap-2 text-sm">
              <i class="bi bi-building text-[var(--accent-cyan)] text-xs" />
              <span class="text-[var(--accent-cyan)] font-medium text-sm">{train.institucion}</span>
            </div>
            <div class="flex items-center gap-2 text-sm">
              <i class="bi bi-calendar-event text-[var(--text-muted)] text-xs" />
              <span class="text-[var(--text-secondary)] text-sm">{train.periodo}</span>
            </div>
          </div>


        </article>
      ))
    }
  </div>
</section>
